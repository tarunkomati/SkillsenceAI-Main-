# Local development defaults. Replace these for production.
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=dev-only-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_USE_X_FORWARDED_HOST=false
DJANGO_SECURE_PROXY_SSL_HEADER=false
DATABASE_URL=sqlite:///db.sqlite3
GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini
AI_REPO_CACHE_ENABLED=true
AI_REPO_CACHE_CHARS=20000
AI_REPO_CHUNK_CHARS=6000
AI_REPO_MAX_FILES=14
AI_REPO_PREVIEW_CHARS=4000
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_API_PROXY_TARGET=http://127.0.0.1:8000
